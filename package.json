{
  "name": "zodiac-constellation-template",
  "author": "Gnosis Guild",
  "license": "LGPL-3.0-only",
  "homepage": "https://github.com/gnosisguild/zodiac-constellation-template",
  "packageManager": "bun@1.3.0",
  "scripts": {
    "format": "prettier --write .",
    "pull": "dotenvx run -- bun --bun ./node_modules/.bin/zodiac pull",
    "pull-org": "dotenvx run -- bun --bun ./node_modules/.bin/zodiac pull-org",
    "pull-contracts": "dotenvx run -- bun --bun ./node_modules/.bin/zodiac pull-contracts",
    "prepush": "bun run pull-org",
    "push": "bun ./.lib/scripts/push.ts"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.51.1",
    "@types/bun": "^1.3.0",
    "@types/yargs": "^17.0.35",
    "@zodiac-os/api-types": "^1.6.0",
    "@zodiac-os/sdk": "^1.7.1",
    "defi-kit": "^2.21.6",
    "dotenv": "^17.2.3",
    "ethers": "^6.13.0",
    "open": "^11.0.0",
    "prettier": "^3.6.2",
    "yargs": "^18.0.0",
    "zodiac-roles-sdk": "^3.3.2"
  }
}
